<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EstruturaPro — Infraestrutura para Eventos</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    /* ── RESET & TOKENS ───────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --black:   #0a0a0b;
      --iron:    #1a1c1f;
      --steel:   #2e3138;
      --ash:     #6b7280;
      --silver:  #c9cdd4;
      --white:   #f4f5f7;
      --amber:   #f59e0b;
      --amber2:  #fbbf24;
      --danger:  #ef4444;
      --font-h:  'Barlow Condensed', sans-serif;
      --font-b:  'Barlow', sans-serif;
      --max:     1280px;
      --radius:  6px;
      --transition: .35s cubic-bezier(.4,0,.2,1);
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--black);
      color: var(--white);
      font-family: var(--font-b);
      font-size: 16px;
      line-height: 1.6;
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }
    img { display: block; width: 100%; }

    /* ── UTILITIES ─────────────────────────────────────────── */
    .container { max-width: var(--max); margin: 0 auto; padding: 0 32px; }
    .badge {
      display: inline-block;
      font-family: var(--font-h);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--amber);
      border: 1px solid var(--amber);
      border-radius: 2px;
      padding: 4px 12px;
      margin-bottom: 20px;
    }
    .section-title {
      font-family: var(--font-h);
      font-size: clamp(38px, 5vw, 62px);
      font-weight: 900;
      line-height: 1.05;
      text-transform: uppercase;
      letter-spacing: .01em;
    }
    .amber { color: var(--amber); }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-h);
      font-weight: 700;
      font-size: 15px;
      letter-spacing: .08em;
      text-transform: uppercase;
      padding: 16px 32px;
      border-radius: var(--radius);
      cursor: pointer;
      border: none;
      transition: var(--transition);
    }
    .btn-amber {
      background: var(--amber);
      color: var(--black);
    }
    .btn-amber:hover { background: var(--amber2); transform: translateY(-2px); box-shadow: 0 8px 32px rgba(245,158,11,.35); }
    .btn-outline {
      background: transparent;
      color: var(--white);
      border: 1.5px solid rgba(255,255,255,.35);
    }
    .btn-outline:hover { border-color: var(--white); background: rgba(255,255,255,.06); transform: translateY(-2px); }

    /* ── FADE-IN ANIMATION ────────────────────────────────── */
    .fade-up {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity .7s ease, transform .7s ease;
    }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    .delay-1 { transition-delay: .12s; }
    .delay-2 { transition-delay: .24s; }
    .delay-3 { transition-delay: .36s; }
    .delay-4 { transition-delay: .48s; }

    /* ── NAVBAR ────────────────────────────────────────────── */
    #navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 18px 0;
      transition: background var(--transition), padding var(--transition), box-shadow var(--transition);
    }
    #navbar.scrolled {
      background: rgba(10,10,11,.92);
      backdrop-filter: blur(16px);
      padding: 12px 0;
      box-shadow: 0 2px 40px rgba(0,0,0,.6);
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      font-family: var(--font-h);
      font-size: 22px;
      font-weight: 900;
      letter-spacing: .04em;
      text-transform: uppercase;
    }
    .logo span { color: var(--amber); }
    .nav-links {
      display: flex;
      gap: 32px;
      list-style: none;
    }
    .nav-links a {
      font-family: var(--font-h);
      font-size: 13px;
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--silver);
      transition: color var(--transition);
    }
    .nav-links a:hover { color: var(--amber); }
    .nav-cta { display: flex; gap: 12px; align-items: center; }
    @media (max-width: 900px) {
      .nav-links { display: none; }
    }

    /* ── HERO ──────────────────────────────────────────────── */
    #hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: flex-end;
      padding-bottom: 80px;
      overflow: hidden;
    }
    .hero-placeholder {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, #1a1c1f 0%, #0d0f12 60%, #1a1008 100%);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    /* Grid texture overlay */
    .hero-placeholder::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(245,158,11,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(245,158,11,.04) 1px, transparent 1px);
      background-size: 60px 60px;
    }
    .img-label {
      position: relative;
      z-index: 2;
      font-family: var(--font-h);
      font-size: 13px;
      letter-spacing: .15em;
      color: var(--ash);
      text-transform: uppercase;
      border: 1px dashed var(--steel);
      padding: 12px 24px;
      border-radius: var(--radius);
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(10,10,11,1) 0%, rgba(10,10,11,.65) 40%, rgba(10,10,11,.2) 100%);
    }
    /* Amber accent bar */
    .hero-accent {
      position: absolute;
      left: 0; bottom: 0;
      width: 4px;
      height: 55%;
      background: linear-gradient(to bottom, transparent, var(--amber));
    }
    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 820px;
    }
    .hero-content h1 {
      font-family: var(--font-h);
      font-size: clamp(44px, 7vw, 90px);
      font-weight: 900;
      line-height: .98;
      text-transform: uppercase;
      letter-spacing: .01em;
      margin-bottom: 24px;
    }
    .hero-content h1 em {
      font-style: normal;
      color: var(--amber);
    }
    .hero-sub {
      font-size: 18px;
      font-weight: 300;
      color: var(--silver);
      max-width: 540px;
      margin-bottom: 40px;
      line-height: 1.55;
    }
    .hero-btns { display: flex; flex-wrap: wrap; gap: 14px; }
    /* Stats strip */
    .hero-stats {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      z-index: 3;
      background: rgba(26,28,31,.85);
      backdrop-filter: blur(12px);
      border-top: 1px solid var(--steel);
      display: none; /* shown via JS after scroll */
    }
    .stats-inner {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      divide: var(--steel);
    }
    .stat-item {
      padding: 20px 32px;
      border-right: 1px solid var(--steel);
      text-align: center;
    }
    .stat-item:last-child { border-right: none; }
    .stat-num {
      font-family: var(--font-h);
      font-size: 36px;
      font-weight: 900;
      color: var(--amber);
      line-height: 1;
    }
    .stat-label {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--ash);
      margin-top: 4px;
    }
    @media (max-width: 640px) {
      .stats-inner { grid-template-columns: repeat(2,1fr); }
    }

    /* ── STATS BANNER (standalone) ────────────────────────── */
    #stats {
      background: var(--iron);
      border-top: 1px solid var(--steel);
      border-bottom: 1px solid var(--steel);
      padding: 0;
    }
    #stats .stats-inner {
      grid-template-columns: repeat(4,1fr);
    }
    @media (max-width: 640px) {
      #stats .stats-inner { grid-template-columns: repeat(2,1fr); }
    }

    /* ── SOLUTIONS ─────────────────────────────────────────── */
    #solutions {
      padding: 100px 0;
      background: var(--black);
    }
    .solutions-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 56px;
      flex-wrap: wrap;
      gap: 24px;
    }
    .solutions-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2px;
    }
    @media (max-width: 900px) { .solutions-grid { grid-template-columns: repeat(2,1fr); } }
    @media (max-width: 560px) { .solutions-grid { grid-template-columns: 1fr; } }

    .solution-card {
      position: relative;
      aspect-ratio: 3/4;
      overflow: hidden;
      cursor: pointer;
      group: true;
    }
    .solution-card::before {
      content: '';
      position: absolute;
      inset: 0;
      transition: opacity var(--transition);
      z-index: 1;
    }
    .solution-card:nth-child(1)::before { background: linear-gradient(to bottom, rgba(10,10,11,0), rgba(10,10,11,.85)); }
    .solution-card:nth-child(2)::before { background: linear-gradient(to bottom, rgba(10,10,11,0), rgba(10,10,11,.85)); }
    .solution-card:nth-child(3)::before { background: linear-gradient(to bottom, rgba(10,10,11,0), rgba(10,10,11,.85)); }
    .solution-card:nth-child(4)::before { background: linear-gradient(to bottom, rgba(10,10,11,0), rgba(10,10,11,.85)); }

    .sol-ph {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-h);
      font-size: 11px;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--ash);
      background: var(--iron);
      border: 1px dashed var(--steel);
      transition: transform .6s ease;
    }
    .solution-card:hover .sol-ph { transform: scale(1.04); }

    .sol-content {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      z-index: 2;
      padding: 28px 24px;
      transform: translateY(12px);
      transition: transform var(--transition);
    }
    .solution-card:hover .sol-content { transform: translateY(0); }
    .sol-icon {
      font-size: 32px;
      margin-bottom: 8px;
      display: block;
    }
    .sol-title {
      font-family: var(--font-h);
      font-size: 24px;
      font-weight: 800;
      text-transform: uppercase;
      margin-bottom: 6px;
      line-height: 1.1;
    }
    .sol-desc {
      font-size: 13px;
      color: var(--silver);
      line-height: 1.5;
      opacity: 0;
      transition: opacity var(--transition) .05s;
      max-height: 0;
      overflow: hidden;
    }
    .solution-card:hover .sol-desc { opacity: 1; max-height: 60px; }
    .sol-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--font-h);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--amber);
      margin-top: 12px;
    }
    .sol-link svg { transition: transform var(--transition); }
    .solution-card:hover .sol-link svg { transform: translateX(4px); }

    /* ── DIFERENCIAIS ──────────────────────────────────────── */
    #diferenciais {
      background: var(--iron);
      padding: 100px 0;
      position: relative;
      overflow: hidden;
    }
    #diferenciais::before {
      content: '';
      position: absolute;
      top: -120px; right: -120px;
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(245,158,11,.07) 0%, transparent 70%);
      pointer-events: none;
    }
    .dif-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 56px 80px;
      margin-top: 64px;
    }
    @media (max-width: 700px) { .dif-grid { grid-template-columns: 1fr; } }
    .dif-item { display: flex; gap: 24px; align-items: flex-start; }
    .dif-num {
      font-family: var(--font-h);
      font-size: 72px;
      font-weight: 900;
      line-height: .85;
      color: rgba(245,158,11,.12);
      flex-shrink: 0;
      width: 64px;
      text-align: right;
      transition: color var(--transition);
    }
    .dif-item:hover .dif-num { color: rgba(245,158,11,.30); }
    .dif-body { flex: 1; }
    .dif-icon {
      width: 44px; height: 44px;
      background: rgba(245,158,11,.1);
      border: 1px solid rgba(245,158,11,.25);
      border-radius: var(--radius);
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
      margin-bottom: 14px;
    }
    .dif-title {
      font-family: var(--font-h);
      font-size: 22px;
      font-weight: 800;
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .dif-text {
      font-size: 14px;
      color: var(--silver);
      line-height: 1.65;
    }

    /* ── PORTFOLIO / PROVA SOCIAL ─────────────────────────── */
    #portfolio {
      padding: 100px 0;
      background: var(--black);
    }
    .port-header {
      text-align: center;
      margin-bottom: 64px;
    }
    .port-header p {
      font-size: 16px;
      color: var(--ash);
      max-width: 520px;
      margin: 16px auto 0;
    }

    /* Client logos */
    .logos-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 2px;
      margin-bottom: 80px;
    }
    .logo-box {
      flex: 1 1 160px;
      height: 80px;
      background: var(--iron);
      border: 1px solid var(--steel);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-h);
      font-size: 11px;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--ash);
      transition: background var(--transition), border-color var(--transition);
    }
    .logo-box:hover { background: var(--steel); border-color: var(--ash); }

    /* Gallery */
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: auto;
      gap: 4px;
      margin-bottom: 80px;
    }
    .g-item {
      background: var(--iron);
      overflow: hidden;
      border-radius: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-h);
      font-size: 11px;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--ash);
      border: 1px dashed var(--steel);
      transition: filter var(--transition);
    }
    .g-item:hover { filter: brightness(1.15); }
    .g1 { grid-column: span 8; grid-row: span 2; aspect-ratio: unset; min-height: 380px; }
    .g2 { grid-column: span 4; min-height: 185px; }
    .g3 { grid-column: span 4; min-height: 185px; }
    .g4 { grid-column: span 4; min-height: 250px; }
    .g5 { grid-column: span 4; min-height: 250px; }
    .g6 { grid-column: span 4; min-height: 250px; }
    @media (max-width: 860px) {
      .g1 { grid-column: 1/-1; min-height: 260px; }
      .g2,.g3 { grid-column: span 6; }
      .g4,.g5,.g6 { grid-column: span 4; }
    }
    @media (max-width: 560px) {
      .g2,.g3,.g4,.g5,.g6 { grid-column: 1/-1; min-height: 200px; }
    }

    /* Testimonials */
    .testimonials {
      display: grid;
      grid-template-columns: repeat(3,1fr);
      gap: 24px;
    }
    @media (max-width: 860px) { .testimonials { grid-template-columns: 1fr; } }
    .testi-card {
      background: var(--iron);
      border: 1px solid var(--steel);
      border-radius: var(--radius);
      padding: 32px;
      position: relative;
      transition: border-color var(--transition), transform var(--transition);
    }
    .testi-card:hover { border-color: var(--ash); transform: translateY(-4px); }
    .testi-quote {
      font-family: var(--font-h);
      font-size: 72px;
      font-weight: 900;
      line-height: .6;
      color: var(--amber);
      margin-bottom: 16px;
      opacity: .35;
    }
    .testi-text {
      font-size: 14px;
      color: var(--silver);
      line-height: 1.7;
      margin-bottom: 24px;
      font-style: italic;
    }
    .testi-author {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .testi-avatar {
      width: 40px; height: 40px;
      border-radius: 50%;
      background: var(--steel);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-h);
      font-size: 14px;
      font-weight: 800;
      color: var(--amber);
      flex-shrink: 0;
    }
    .testi-name {
      font-family: var(--font-h);
      font-size: 15px;
      font-weight: 700;
      text-transform: uppercase;
    }
    .testi-role {
      font-size: 12px;
      color: var(--ash);
    }

    /* ── COBERTURA REGIONAL ───────────────────────────────── */
    #regional {
      background: var(--iron);
      padding: 80px 0;
      border-top: 1px solid var(--steel);
      border-bottom: 1px solid var(--steel);
    }
    .regional-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
    }
    @media (max-width: 700px) { .regional-inner { grid-template-columns: 1fr; } }
    .regional-map-ph {
      aspect-ratio: 4/3;
      background: var(--black);
      border-radius: var(--radius);
      border: 1px dashed var(--steel);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-h);
      font-size: 11px;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--ash);
    }
    .regional-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 24px;
    }
    .r-tag {
      font-family: var(--font-h);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
      padding: 6px 14px;
      border: 1px solid var(--steel);
      border-radius: 2px;
      color: var(--silver);
      background: var(--black);
      transition: var(--transition);
    }
    .r-tag:hover { border-color: var(--amber); color: var(--amber); }

    /* ── CTA BANNER ───────────────────────────────────────── */
    #cta-banner {
      padding: 100px 0;
      background: var(--black);
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    #cta-banner::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(245,158,11,.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(245,158,11,.03) 1px, transparent 1px);
      background-size: 48px 48px;
    }
    .cta-inner {
      position: relative; z-index: 1;
    }
    .cta-title {
      font-family: var(--font-h);
      font-size: clamp(42px, 6vw, 80px);
      font-weight: 900;
      line-height: 1.0;
      text-transform: uppercase;
      margin-bottom: 24px;
    }
    .cta-sub {
      font-size: 16px;
      color: var(--ash);
      margin-bottom: 40px;
    }
    .cta-btns { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; }

    /* ── FOOTER ───────────────────────────────────────────── */
    footer {
      background: var(--iron);
      border-top: 1px solid var(--steel);
      padding: 64px 0 32px;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
      gap: 48px;
      margin-bottom: 48px;
    }
    @media (max-width: 860px) { .footer-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 560px) { .footer-grid { grid-template-columns: 1fr; } }
    .footer-logo {
      font-family: var(--font-h);
      font-size: 28px;
      font-weight: 900;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .footer-tagline {
      font-size: 13px;
      color: var(--ash);
      line-height: 1.6;
      max-width: 280px;
      margin-bottom: 24px;
    }
    .social-links { display: flex; gap: 10px; }
    .social-btn {
      width: 38px; height: 38px;
      background: var(--steel);
      border-radius: var(--radius);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
      transition: background var(--transition), transform var(--transition);
    }
    .social-btn:hover { background: var(--amber); transform: translateY(-2px); }
    .footer-col h4 {
      font-family: var(--font-h);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 20px;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-col a {
      font-size: 14px;
      color: var(--ash);
      transition: color var(--transition);
    }
    .footer-col a:hover { color: var(--white); }
    .contact-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 14px;
      color: var(--ash);
      margin-bottom: 12px;
      line-height: 1.5;
    }
    .contact-icon { flex-shrink: 0; font-size: 16px; margin-top: 2px; }
    .footer-bottom {
      border-top: 1px solid var(--steel);
      padding-top: 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }
    .footer-bottom p { font-size: 13px; color: var(--ash); }
    .footer-bottom a { color: var(--amber); transition: opacity var(--transition); }
